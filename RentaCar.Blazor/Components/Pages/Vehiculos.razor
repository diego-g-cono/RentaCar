@page "/vehiculos"
@inject IHttpClientFactory HttpFactory
@inject AuthService Auth
@inject NavigationManager Nav
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using RentaCar.Dtos.Vehiculos
@using RentaCar.Blazor.Services

<h3 class="title">Autos disponibles</h3>

@if (vehiculos == null)
{
    <p class="loading">Cargando...</p>
}
else if (!vehiculos.Any())
{
    <p class="empty">No hay autos disponibles</p>
}
else
{
    <div class="filtro-container">
        <label>Tipo de vehículo</label>

        <InputSelect @bind-Value="tipoSeleccionado" class="filtro-select">
            <option value="">Todos</option>

            @foreach (var tipo in tiposVehiculo)
            {
                <option value="@tipo">@tipo</option>
            }
        </InputSelect>
    </div>
    <div class="grid">
        @foreach (var v in VehiculosFiltrados)
        {
            <div class="auto-card">
                <div class="img-container">

                    <img src="@ObtenerImagen(v)"
                         class="auto-img" />

                    @if (Auth.PuedeEditarVehiculos)
                    {
                        <label class="btn-editar">
                            ✏️
                            <InputFile class="input-oculto"
                                       OnChange="@(e => SubirImagen(e, v.Patente))" />
                        </label>
                    }

                </div>

                <h4>@v.MarcaNombre @v.ModeloNombre</h4>

                <span class="badge @ObtenerClaseTipo(v.TipoNombre)">
                    @v.TipoNombre
                </span>

                <p class="patente">@v.CombustibleNombre</p>

                <button class="btn-reservar"
                        @onclick="() => Reservar(v.Patente)">
                    Reservar
                </button>
            </div>
        }
    </div>
}

@code {
    private List<VehiculoResponse>? vehiculos;
    private string tipoSeleccionado = "";

    private List<string> tiposVehiculo = new();

    private IEnumerable<VehiculoResponse> VehiculosFiltrados =>
        string.IsNullOrWhiteSpace(tipoSeleccionado)
            ? vehiculos ?? Enumerable.Empty<VehiculoResponse>()
            : vehiculos?.Where(v => v.TipoNombre == tipoSeleccionado)
                ?? Enumerable.Empty<VehiculoResponse>();

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var inicio = query["inicio"];
        var fin = query["fin"];

        var client = HttpFactory.CreateClient("Api");

        vehiculos = await client.GetFromJsonAsync<List<VehiculoResponse>>(
            $"vehiculos/disponibles?fechaInicio={inicio}&fechaFin={fin}"
        );

        tiposVehiculo = vehiculos?
            .Select(v => v.TipoNombre)
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .Distinct()
            .OrderBy(t => t)
            .ToList()
            ?? new();
    }
    private string ObtenerImagen(VehiculoResponse v)
    {
        return string.IsNullOrWhiteSpace(v.ImagenUrl)
            ? "images/autos/default.png"
            : v.ImagenUrl;
    }
    private void Reservar(string patente)
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var inicio = query["inicio"];
        var fin = query["fin"];

        var urlReserva =
            $"/reserva?patente={patente}&inicio={inicio}&fin={fin}";

        if (!Auth.EstaLogueado)
        {
            Nav.NavigateTo(
                $"/login?returnUrl={Uri.EscapeDataString(urlReserva)}");

            return;
        }

        Nav.NavigateTo(urlReserva);
    }
    private string ObtenerClaseTipo(string? tipo)
    {
        return tipo?.ToLower() switch
        {
            "suv" => "badge-suv",
            "hatchback" => "badge-hatchback",
            "sedán" => "badge-sedan",
            "pickup" => "badge-pickup",
            _ => ""
        };
    }
    private async Task SubirImagen(InputFileChangeEventArgs e, string patente)
    {
        var archivo = e.File;

        using var contenido = new MultipartFormDataContent();

        contenido.Add(
            new StreamContent(
                archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024)),
            "archivo",
            archivo.Name);

        var client = HttpFactory.CreateClient("Api");

        var response = await client.PostAsync(
            $"vehiculos/{patente}/imagen",
            contenido);

        if (response.IsSuccessStatusCode)
        {
            // Recargar lista para mostrar la nueva imagen
            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

            var inicio = query["inicio"];
            var fin = query["fin"];

            vehiculos = await client.GetFromJsonAsync<List<VehiculoResponse>>(
                $"vehiculos/disponibles?fechaInicio={inicio}&fechaFin={fin}");
        }
    }
}

<style>
    body {
        background: #0f172a;
        color: #e5e7eb;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .title {
        text-align: center;
        margin-top: 30px;
        font-size: 28px;
    }

    .loading, .empty {
        text-align: center;
        margin-top: 30px;
        color: #94a3b8;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 250px));
        justify-content: center;
        gap: 20px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 30px;
    }

    .auto-card {
        background: #1e293b;
        padding: 20px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .auto-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.6);
        }

        .auto-card h4 {
            margin-bottom: 10px;
            font-size: 18px;
        }

    .info {
        margin-bottom: 10px;
    }

    .badge {
        background: #3b82f6;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: bold;
    }

    .patente {
        font-size: 14px;
        color: #94a3b8;
        margin-bottom: 15px;
    }

    .btn-reservar {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-reservar:hover {
            opacity: 0.9;
        }

    .auto-img {
        width: 100%;
        height: 140px;
        object-fit: cover;
        border-radius: 10px;
        margin-bottom: 10px;
        background: #0f172a;
    }

    .badge {
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: bold;
        color: white;
    }

    .badge-suv {
        background: #f59e0b;
    }
    .badge-hatchback {
        background: #3b82f6;
    }

    .badge-sedan {
        background: #8b5cf6;
    }

    .badge-pickup {
        background: #ef4444;
    }

    .filtro-container {
        max-width: 300px;
        margin: 20px auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filtro-container label {
            color: #cbd5e1;
            font-size: 14px;
        }

    .filtro-select {
        background: #1e293b;
        color: #e5e7eb;
        border: 1px solid #334155;
        border-radius: 10px;
        padding: 10px;
    }

    .img-container {
        position: relative;
    }

    .btn-editar {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(15,23,42,.9);
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #334155;
        transition: .2s;
    }

        .btn-editar:hover {
            background: #2563eb;
        }

    .input-oculto {
        display: none;
    }
</style>