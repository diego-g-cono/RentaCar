@page "/vehiculos"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@rendermode InteractiveServer
@using RentaCar.Dtos.Vehiculos


<h3 class="title">Autos disponibles</h3>

@if (vehiculos == null)
{
    <p class="loading">Cargando...</p>
}
else if (!vehiculos.Any())
{
    <p class="empty">No hay autos disponibles 😕</p>
}
else
{
    <div class="grid">
        @foreach (var v in vehiculos)
        {
            <div class="auto-card">
                <img src="@ObtenerImagen(v)" class="auto-img" />

                <h4>@v.MarcaNombre @v.ModeloNombre</h4>

                <div class="info">
                    <span class="badge">@v.TipoNombre</span>
                </div>

                <p class="patente">@v.CombustibleNombre</p>

                <button class="btn-reservar"
                        @onclick="() => Reservar(v.Patente)">
                    Reservar
                </button>
            </div>
        }
    </div>
}

@code {
    private List<VehiculoResponse>? vehiculos;

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var inicio = query["inicio"];
        var fin = query["fin"];

        var client = HttpFactory.CreateClient("Api");

        vehiculos = await client.GetFromJsonAsync<List<VehiculoResponse>>(
            $"vehiculos/disponibles?fechaInicio={inicio}&fechaFin={fin}"
        );
    }
    private string ObtenerImagen(VehiculoResponse v)
    {
        var marca = v.MarcaNombre?.ToLower().Replace(" ", "-");
        var modelo = v.ModeloNombre?.ToLower().Replace(" ", "-");

        return $"images/autos/{marca}-{modelo}.png";
    }
    private void Reservar(string patente)
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var inicio = query["inicio"];
        var fin = query["fin"];

        var url = $"/reserva?patente={patente}&inicio={inicio}&fin={fin}";

        Nav.NavigateTo(url);
    }
}

<style>
    body {
        background: #0f172a;
        color: #e5e7eb;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .title {
        text-align: center;
        margin-top: 30px;
        font-size: 28px;
    }

    .loading, .empty {
        text-align: center;
        margin-top: 30px;
        color: #94a3b8;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        padding: 30px;
    }

    .auto-card {
        background: #1e293b;
        padding: 20px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .auto-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.6);
        }

        .auto-card h4 {
            margin-bottom: 10px;
            font-size: 18px;
        }

    .info {
        margin-bottom: 10px;
    }

    .badge {
        background: #3b82f6;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: bold;
    }

    .patente {
        font-size: 14px;
        color: #94a3b8;
        margin-bottom: 15px;
    }

    .btn-reservar {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-reservar:hover {
            opacity: 0.9;
        }

    .auto-img {
        width: 100%;
        height: 140px;
        object-fit: cover;
        border-radius: 10px;
        margin-bottom: 10px;
        background: #0f172a;
    }
</style>