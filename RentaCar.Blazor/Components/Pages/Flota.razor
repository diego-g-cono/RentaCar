@page "/flota"
@inject IHttpClientFactory HttpFactory
@using RentaCar.Dtos.Vehiculos

<div class="page-container">

    <h3 class="titulo">Nuestra flota</h3>

    @if (vehiculos == null)
    {
        <p class="loading">Cargando vehículos...</p>
    }
    else if (!vehiculos.Any())
    {
        <p class="empty">No hay vehículos disponibles 😕</p>
    }
    else
    {
        <div class="filtro-container">
            <label>Filtrar por tipo de vehículo:</label>

            <select @bind="tipoSeleccionado">
                <option value="">Todos</option>

                @foreach (var tipo in tiposVehiculo)
                {
                    <option value="@tipo">@tipo</option>
                }
            </select>
        </div>
        <div class="grid">
            @foreach (var v in VehiculosFiltrados)
            {
                <div class="auto-card">
                    <img src="@ObtenerImagen(v)"
                         class="auto-img"
                         onerror="this.src='images/autos/default.jpg'" />

                    <h4>@v.MarcaNombre @v.ModeloNombre</h4>

                    <span class="badge @ObtenerClaseTipo(v.TipoNombre)">
                        @v.TipoNombre
                    </span>

                    <p class="patente">@v.CombustibleNombre</p>
                </div>
            }
        </div>
    }

</div>

@code {
    private List<VehiculoResponse>? vehiculos;
    private string tipoSeleccionado = "";

    private List<string> tiposVehiculo = new();

    private IEnumerable<VehiculoResponse> VehiculosFiltrados =>
        string.IsNullOrWhiteSpace(tipoSeleccionado)
            ? vehiculos ?? Enumerable.Empty<VehiculoResponse>()
            : vehiculos?.Where(v => v.TipoNombre == tipoSeleccionado)
                ?? Enumerable.Empty<VehiculoResponse>();

    protected override async Task OnInitializedAsync()
    {
        var client = HttpFactory.CreateClient("Api");

        vehiculos = await client.GetFromJsonAsync<List<VehiculoResponse>>("vehiculos");

        tiposVehiculo = vehiculos?
            .Select(v => v.TipoNombre)
            .Distinct()
            .OrderBy(t => t)
            .ToList()
            ?? new();
    }

    private string ObtenerImagen(VehiculoResponse v)
    {
        var marca = v.MarcaNombre?.ToLower().Replace(" ", "-");
        var modelo = v.ModeloNombre?.ToLower().Replace(" ", "-");

        return $"images/autos/{marca}-{modelo}.png";
    }
    private string ObtenerClaseTipo(string? tipo)
    {
        return tipo?.ToLower() switch
        {
            "suv" => "badge-suv",
            "hatchback" => "badge-hatchback",
            "sedán" => "badge-sedan",
            "sedan" => "badge-sedan",
            "pickup" => "badge-pickup",
            _ => ""
        };
    }
}
<style>
    html, body {
        margin: 0;
        padding: 0;
        background: #0f172a;
    }
    .titulo {
        text-align: center;
        margin-bottom: 30px;
        font-size: 28px;
    }

    .loading, .empty {
        text-align: center;
        color: #94a3b8;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        max-width: 1200px;
        margin: auto;
    }

    .auto-card {
        background: #1e293b;
        padding: 15px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 6px 20px rgba(0,0,0,0.4);
        transition: all 0.2s;
    }

        .auto-card:hover {
            transform: translateY(-5px); /* mejor que scale */
        }

    .auto-img {
        width: 100%;
        height: 140px;
        object-fit: contain;
        background: #0f172a;
        border-radius: 10px;
        margin-bottom: 10px;
    }

    .badge {
        display: inline-block;
        background: #2563eb;
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 12px;
        margin-bottom: 8px;
    }

    .patente {
        color: #94a3b8;
        font-size: 14px;
    }

    .page-container {
        min-height: calc(100vh - 60px); /* resta navbar */
        padding: 40px 20px;
        color: #e5e7eb;
    }

    .filtro-container {
        max-width: 300px;
        margin: 0 auto 25px auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filtro-container label {
            color: #cbd5e1;
            font-size: 14px;
        }

        .filtro-container select {
            background: #1e293b;
            color: #e5e7eb;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 10px;
        }

    .badge-suv {
        background: #f59e0b;
    }

    .badge-hatchback {
        background: #3b82f6;
    }

    .badge-sedan {
        background: #8b5cf6;
    }

    .badge-pickup {
        background: #ef4444;
    }
</style>