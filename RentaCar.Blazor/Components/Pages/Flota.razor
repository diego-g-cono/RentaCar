@page "/flota"
@inject AuthService Auth
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@using RentaCar.Dtos.Vehiculos
@using RentaCar.Blazor.Services

<div class="page-container">

    <h3 class="titulo">Nuestra flota</h3>

    @if (vehiculos == null)
    {
        <p class="loading">Cargando vehículos...</p>
    }
    else if (!vehiculos.Any())
    {
        <p class="empty">No hay vehículos disponibles 😕</p>
    }
    else
    {
        <div class="filtro-container">
            <label>Filtrar por tipo de vehículo:</label>

            <select @bind="tipoSeleccionado">
                <option value="">Todos</option>

                @foreach (var tipo in tiposVehiculo)
                {
                    <option value="@tipo">@tipo</option>
                }
            </select>
        </div>
        <div class="grid">
            @foreach (var v in VehiculosFiltrados)
            {
                <div class="auto-card">
                    <div class="imagen-container">
                        <img src="@ObtenerImagen(v)" class="auto-img" />

                        @if (Auth.PuedeEditarVehiculos)
                        {
                            <label class="btn-editar">
                                ✏️
                                <InputFile class="input-oculto"
                                           OnChange="@(e => SubirImagen(e, v.Patente))" />
                            </label>
                        }
                    </div>

                    <h4>@v.MarcaNombre @v.ModeloNombre</h4>

                    <span class="badge @ObtenerClaseTipo(v.TipoNombre)">
                        @v.TipoNombre
                    </span>

                    <p class="patente">@v.CombustibleNombre</p>
                </div>
            }
        </div>
    }

</div>

@code {
    private List<VehiculoResponse>? vehiculos;
    private string tipoSeleccionado = "";

    private List<string> tiposVehiculo = new();

    private IEnumerable<VehiculoResponse> VehiculosFiltrados =>
        string.IsNullOrWhiteSpace(tipoSeleccionado)
            ? vehiculos ?? Enumerable.Empty<VehiculoResponse>()
            : vehiculos?.Where(v => v.TipoNombre == tipoSeleccionado)
                ?? Enumerable.Empty<VehiculoResponse>();

    protected override async Task OnInitializedAsync()
    {
        var client = HttpFactory.CreateClient("Api");

        vehiculos = (await client.GetFromJsonAsync<List<VehiculoResponse>>("vehiculos"))
    ?.Where(v => v.EstadoId == 1)
    .ToList();

        tiposVehiculo = vehiculos?
            .Select(v => v.TipoNombre)
            .Distinct()
            .OrderBy(t => t)
            .ToList()
            ?? new();
    }

    private string ObtenerImagen(VehiculoResponse v)
    {
        if (string.IsNullOrWhiteSpace(v.ImagenUrl))
            return "https://localhost:7272/images/autos/default.png";

        if (v.ImagenUrl.StartsWith("http"))
            return v.ImagenUrl;

        return $"https://localhost:7272{v.ImagenUrl}";
    }
    private string ObtenerClaseTipo(string? tipo)
    {
        return tipo?.ToLower() switch
        {
            "suv" => "badge-suv",
            "hatchback" => "badge-hatchback",
            "sedán" => "badge-sedan",
            "sedan" => "badge-sedan",
            "pickup" => "badge-pickup",
            _ => ""
        };
    }
    private async Task SubirImagen(InputFileChangeEventArgs e, string patente)
    {
        var archivo = e.File;

        using var contenido = new MultipartFormDataContent();

        contenido.Add(
            new StreamContent(
                archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024)),
            "archivo",
            archivo.Name);

        var client = HttpFactory.CreateClient("Api");

        var response = await client.PostAsync(
            $"vehiculos/{patente}/imagen",
            contenido);

        if (response.IsSuccessStatusCode)
        {
            vehiculos = (await client.GetFromJsonAsync<List<VehiculoResponse>>("vehiculos"))
    ?.Where(v => v.EstadoId == 1)
    .ToList();

            tiposVehiculo = vehiculos?
                .Select(v => v.TipoNombre)
                .Where(t => !string.IsNullOrWhiteSpace(t))
                .Distinct()
                .OrderBy(t => t)
                .ToList()
                ?? new();

            StateHasChanged();
        }
    }
}
<style>
    html, body {
        margin: 0;
        padding: 0;
        background: #0f172a;
    }
    .titulo {
        text-align: center;
        margin-bottom: 30px;
        font-size: 28px;
    }

    .loading, .empty {
        text-align: center;
        color: #94a3b8;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        max-width: 1200px;
        margin: auto;
    }

    .auto-card {
        background: #1e293b;
        padding: 15px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 6px 20px rgba(0,0,0,0.4);
        transition: all 0.2s;
    }

        .auto-card:hover {
            transform: translateY(-5px); /* mejor que scale */
        }

    .auto-img {
        width: 100%;
        height: 140px;
        object-fit: contain;
        background: #0f172a;
        border-radius: 10px;
        margin-bottom: 10px;
    }

    .badge {
        display: inline-block;
        background: #2563eb;
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 12px;
        margin-bottom: 8px;
    }

    .patente {
        color: #94a3b8;
        font-size: 14px;
    }

    .page-container {
        min-height: calc(100vh - 60px); /* resta navbar */
        padding: 40px 20px;
        color: #e5e7eb;
    }

    .filtro-container {
        max-width: 300px;
        margin: 0 auto 25px auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filtro-container label {
            color: #cbd5e1;
            font-size: 14px;
        }

        .filtro-container select {
            background: #1e293b;
            color: #e5e7eb;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 10px;
        }

    .badge-suv {
        background: #f59e0b;
    }

    .badge-hatchback {
        background: #3b82f6;
    }

    .badge-sedan {
        background: #8b5cf6;
    }

    .badge-pickup {
        background: #ef4444;
    }

    .imagen-container {
        position: relative;
    }

    .btn-editar {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: rgba(15,23,42,.9);
        border: 1px solid #334155;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: .2s;
        font-size: 16px;
    }

        .btn-editar:hover {
            background: #1e293b;
            transform: scale(1.1);
        }

    .input-oculto {
        display: none;
    }

</style>