@page "/login"
@inject AuthService Auth
@inject NavigationManager Nav
@rendermode InteractiveServer
@using RentaCar.Blazor.Services
@using RentaCar.Dtos.Usuarios
@using System.Text.RegularExpressions;

<div class="login-bg">
    <div class="login-card">

        <h3 class="titulo">Iniciar sesión</h3>

        <div class="form">

            <div class="input-group">
                <label>Usuario</label>
                <input @bind="usuario" placeholder="Ingrese su usuario" />
            </div>

            <div class="input-group">
                <label>Contraseña</label>
                <input type="password" @bind="password" placeholder="••••••••" />
            </div>

            <button class="btn" @onclick="LoginClick">
                Ingresar
            </button>
            <div class="registro-link">
                <span>No tengo una cuenta</span>

                <button class="btn-link"
                        @onclick="() => mostrarRegistro = !mostrarRegistro">
                    Registrarme
                </button>
            </div>
            @if (loginExitoso)
            {
                <div class="success">
                    ¡Bienvenido @Auth.NombreUsuario!
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <p class="error">@error</p>
            }
            @if (mostrarRegistro)
            {
                <div class="registro-form">

                    <h4>Crear cuenta</h4>

                    <div class="input-group">
                        <label>DNI</label>
                        <input type="text"
                               inputmode="numeric"
                               pattern="[0-9]*"
                               maxlength="8"
                               @bind="nuevoDniTexto" />
                    </div>

                    <div class="input-group">
                        <label>Nombre</label>
                        <input @bind="nuevoNombre" />
                    </div>

                    <div class="input-group">
                        <label>Apellido</label>
                        <input @bind="nuevoApellido" />
                    </div>
                    <div class="input-group">
                        <label>E-mail</label>
                        <input type="email" @bind="nuevoEmail" />
                    </div>

                    <div class="input-group">
                        <label>Teléfono</label>
                        <input type="tel"
                               pattern="[0-9]*"
                               @bind="nuevoTelefono" />
                    </div>

                    <div class="input-group">
                        <label>Usuario</label>
                        <input @bind="nuevoUsuario" />
                    </div>

                    <div class="input-group">
                        <label>Contraseña</label>
                        <input type="password" @bind="nuevoPassword" />
                    </div>

                    <button class="btn btn-registro"
                            @onclick="Registrar">
                        Crear cuenta
                    </button>

                </div>
            }

        </div>
    </div>
</div>

@code {
    private string usuario = "";
    private string password = "";
    private string error = "";
    private string nuevoDniTexto = "";
    private bool loginExitoso = false;
    private bool mostrarRegistro = false;

    private int nuevoDni;
    private string nuevoNombre = "";
    private string nuevoApellido = "";
    private string nuevoUsuario = "";
    private string nuevoPassword = "";
    private string nuevoEmail = "";
    private string nuevoTelefono = "";
    private string? returnUrl;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);

        var query =
            System.Web.HttpUtility.ParseQueryString(uri.Query);

        returnUrl = query["returnUrl"];
    }

    private async Task LoginClick()
    {
        error = "";

        var ok = await Auth.Login(usuario, password);

        if (ok)
        {
            loginExitoso = true;

            StateHasChanged();

            await Task.Delay(1500);

            if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                Nav.NavigateTo(returnUrl);
            }
            else
            {
                Nav.NavigateTo("/");
            }
        }
        else
        {
            error = "Usuario o contraseña incorrectos";
        }
    }
    private async Task Registrar()
    {
        error = "";
        if (!int.TryParse(nuevoDniTexto, out int nuevoDni))
        {
            error = "Ingrese un DNI válido";
            return;
        }
        if (nuevoDni < 1000000)
        {
            error = "Ingrese un DNI válido";
            return;
        }

        // Validar campos obligatorios
        if (nuevoDni <= 0 ||
            string.IsNullOrWhiteSpace(nuevoNombre) ||
            string.IsNullOrWhiteSpace(nuevoApellido) ||
            string.IsNullOrWhiteSpace(nuevoEmail) ||
            string.IsNullOrWhiteSpace(nuevoTelefono) ||
            string.IsNullOrWhiteSpace(nuevoUsuario) ||
            string.IsNullOrWhiteSpace(nuevoPassword))
        {
            error = "Todos los campos son obligatorios.";
            return;
        }

        // Validar nombre
        if (!Regex.IsMatch(
            nuevoNombre.Trim(),
            @"^[A-Za-zÁÉÍÓÚáéíóúÑñ]+(?:\s[A-Za-zÁÉÍÓÚáéíóúÑñ]+)*$"))
        {
            error = "El nombre sólo puede contener letras.";
            return;
        }

        // Validar apellido
        if (!Regex.IsMatch(
            nuevoApellido.Trim(),
            @"^[A-Za-zÁÉÍÓÚáéíóúÑñ]+(?:\s[A-Za-zÁÉÍÓÚáéíóúÑñ]+)*$"))
        {
            error = "El apellido sólo puede contener letras.";
            return;
        }

        // Validar email
        if (!Regex.IsMatch(
            nuevoEmail,
            @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            error = "Ingrese un e-mail válido.";
            return;
        }

        // Validar teléfono
        if (!Regex.IsMatch(nuevoTelefono, @"^[0-9]+$"))
        {
            error = "El teléfono sólo puede contener números.";
            return;
        }

        try
        {
            var client = new HttpClient
            {
                BaseAddress = new Uri("https://localhost:7272/api/")
            };

            // Verificar usuario duplicado
            var existeUsuario = await client.GetAsync(
                $"usuarios/existe/{nuevoUsuario}");

            if (existeUsuario.IsSuccessStatusCode)
            {
                var existe = await existeUsuario.Content
                    .ReadFromJsonAsync<bool>();

                if (existe)
                {
                    error = "El nombre de usuario ya existe.";
                    return;
                }
            }

            var request = new
            {
                Dni = nuevoDni,
                Nombre = nuevoNombre,
                Apellido = nuevoApellido,
                Email = nuevoEmail,
                Telefono = nuevoTelefono,
                NombreUsuario = nuevoUsuario,
                Contrasenia = nuevoPassword
            };

            var response = await client.PostAsJsonAsync(
                "usuarios/registrar",
                request
            );

            if (response.IsSuccessStatusCode)
            {
                error = "";
                mostrarRegistro = false;

                usuario = nuevoUsuario;
                password = nuevoPassword;

                await LoginClick();
            }
            else
            {
                error = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
}

<style>
    .login-bg {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 70px);
        padding: 30px;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        background: rgba(30, 41, 59, 0.92);
        padding: 35px;
        border-radius: 18px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.45);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.06);
        animation: fadeIn 0.4s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .titulo {
        text-align: center;
        margin-bottom: 20px;
        font-size: 24px;
        color: #e5e7eb;
    }

    .form {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .input-group {
        display: flex;
        flex-direction: column;
    }

    label {
        font-size: 13px;
        margin-bottom: 5px;
        color: #cbd5f5;
    }

    input {
        background: #020617;
        border: 1px solid #334155;
        border-radius: 10px;
        padding: 10px;
        color: #e5e7eb;
        transition: 0.2s;
    }

        input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px rgba(59,130,246,0.3);
        }

    .btn {
        margin-top: 10px;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn:hover {
            transform: scale(1.03);
            box-shadow: 0 5px 20px rgba(37,99,235,0.5);
        }

    .error {
        color: #f87171;
        text-align: center;
        font-size: 14px;
        margin-top: 5px;
    }

    .success {
        margin-top: 15px;
        background: rgba(34,197,94,0.15);
        border: 1px solid #22c55e;
        color: #86efac;
        padding: 12px;
        border-radius: 10px;
        text-align: center;
        animation: fadeIn 0.3s ease;
    }
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(5px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .registro-link {
        margin-top: 10px;
        text-align: center;
        color: #94a3b8;
        font-size: 14px;
    }

    .btn-link {
        background: none;
        border: none;
        color: #60a5fa;
        cursor: pointer;
        margin-left: 5px;
        font-weight: bold;
    }

        .btn-link:hover {
            text-decoration: underline;
        }

    .registro-form {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #334155;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

        .registro-form h4 {
            text-align: center;
            color: #e5e7eb;
            margin-bottom: 5px;
        }

    .btn-registro {
        background: linear-gradient(135deg, #22c55e, #16a34a);
    }

        .btn-registro:hover {
            box-shadow: 0 5px 20px rgba(34,197,94,0.4);
        }

    .sin-flechas::-webkit-outer-spin-button,
    .sin-flechas::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .sin-flechas {
        -moz-appearance: textfield;
    }
</style>