@page "/reserva"
@inject IHttpClientFactory HttpFactory
@inject AuthService Auth
@inject NavigationManager Nav
@inject AuthService Auth
@rendermode InteractiveServer
@using RentaCar.Dtos.Reservas
@using RentaCar.Dtos.Vehiculos
@using RentaCar.Blazor.Services

<h3 class="titulo">Crear reserva</h3>

@if (reserva == null)
{
    <p class="error">Error: no se pudo inicializar la reserva</p>
}
else
{
    <div class="form">

        <div class="vehiculo">
            <span>Vehículo</span>
            <strong>@(vehiculoDescripcion ?? reserva.VehiculoPatente)</strong>
        </div>

        <div class="input-group">
            <label>DNI Cliente</label>
            <input type="number"
                   @bind="reserva.ClienteDni"
                   readonly />
        </div>

        <div class="input-group">
            <label>Nombre Cliente</label>
            <input type="text"
                   @bind="reserva.ClienteNombre"
                   readonly />
        </div>

        <div class="input-group">
            <label>Fecha inicio</label>
            <InputDate @bind-Value="fechaInicio" />
        </div>

        <div class="input-group">
            <label>Fecha fin</label>
            <InputDate @bind-Value="fechaFin" />
        </div>

        <div class="input-group">
            <label>Seña</label>
            <input type="number" step="0.01" @bind="reserva.Senia" />
        </div>

        <button class="btn" @onclick="ConfirmarReserva">
            Confirmar reserva
        </button>

    </div>
}



@code {
    private ReservaResponse? reserva;

    private DateTime fechaInicio;
    private DateTime fechaFin;
    private string? vehiculoDescripcion;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.EstaLogueado)
        {
            Nav.NavigateTo("/login");
            return;
        }
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        reserva = new ReservaResponse
        {
            ClienteDni = Auth.ClienteDni,
            ClienteNombre = Auth.ClienteNombre
        };

        reserva.VehiculoPatente = query["patente"] ?? "SIN-PATENTE";

        var client = HttpFactory.CreateClient("Api");

        var vehiculo = await client.GetFromJsonAsync<VehiculoResponse>($"vehiculos/{reserva.VehiculoPatente}");

        if (vehiculo != null)
        {
            vehiculoDescripcion = $"{vehiculo.MarcaNombre} {vehiculo.ModeloNombre}";
        }

        var inicioStr = query["inicio"];
        var finStr = query["fin"];

        fechaInicio = DateTime.TryParse(inicioStr, out var inicio)
            ? inicio
            : DateTime.Today;

        fechaFin = DateTime.TryParse(finStr, out var fin)
            ? fin
            : DateTime.Today.AddDays(1);

        reserva.FechaInicio = DateOnly.FromDateTime(fechaInicio);
        reserva.FechaFin = DateOnly.FromDateTime(fechaFin);

        reserva.EstadoId = 1;
        reserva.EstadoNombre = "Pendiente";
    }

    private async Task ConfirmarReserva()
    {
        var client = HttpFactory.CreateClient("Api");

        try
        {

            var request = new ReservaCreateRequest
            {
                ClienteDni = reserva!.ClienteDni,
                VehiculoPatente = reserva.VehiculoPatente,
                FechaInicio = DateOnly.FromDateTime(fechaInicio),
                FechaFin = DateOnly.FromDateTime(fechaFin),
                Precio = reserva.Precio,
                Senia = reserva.Senia,
                EstadoId = 1 
            };
            Console.WriteLine(request);
            

            var response = await client.PostAsJsonAsync("reservas", request);

            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine("Reserva creada correctamente");

         
                Nav.NavigateTo("/flota");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error: {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error de conexión: {ex.Message}");
        }
    }
}

