@page "/reserva"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject AuthService Auth
@rendermode InteractiveServer
@using RentaCar.Dtos.Reservas
@using RentaCar.Dtos.Vehiculos
@using RentaCar.Blazor.Services
@using RentaCar.Dtos.Seguros

<h3 class="titulo">Crear reserva</h3>

@if (reserva == null)
{
    <p class="error">Error: no se pudo inicializar la reserva</p>
}
else
{
    <div class="form">

        <div class="vehiculo">
            <span>Vehículo</span>
            <strong>@(vehiculoDescripcion ?? reserva.VehiculoPatente)</strong>
        </div>

        <div class="input-group">
            <label>DNI Cliente</label>
            <input type="number"
                   @bind="reserva.ClienteDni"
                   readonly />
        </div>

        <div class="input-group">
            <label>Nombre Cliente</label>
            <input type="text"
                   @bind="reserva.ClienteNombre"
                   readonly />
        </div>

        <div class="input-group">
            <label>Apellido Cliente</label>
            <input type="text"
                   @bind="reserva.ClienteApellido"
                   readonly />
        </div>

        <div class="input-group">
            <label>Fecha inicio</label>
            <InputDate @bind-Value="fechaInicio" readonly/>
        </div>

        <div class="input-group">
            <label>Fecha fin</label>
            <InputDate @bind-Value="fechaFin" readonly/>
        </div>
        <div class="input-group">
            <label>Seguro</label>

            <select @bind="seguroId"
                    @bind:after="CalcularPrecio">
                @foreach (var s in seguros)
                {
                    <option value="@s.Id">
                        @s.Nombre
                    </option>
                }
            </select>
        </div>

        <div class="input-group">
            <label>Seña</label>
            <input type="number" step="0.01" @bind="reserva.Senia" />
        </div>
        <div class="precio-box">
            <span>Precio total</span>
            <strong>$ @precioTotal.ToString("N2")</strong>
        </div>

        <button class="btn" @onclick="ConfirmarReserva">
            Confirmar reserva
        </button>
        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="@(reservaExitosa ? "success" : "error-box")">
                @mensaje
            </div>
        }

    </div>
}



@code {
    private ReservaResponse? reserva;

    private DateTime fechaInicio;
    private DateTime fechaFin;
    private string? vehiculoDescripcion;
    private string mensaje = "";
    private bool reservaExitosa = false;
    private decimal precioTotal;

    private int seguroId = 1;

    private List<SeguroResponse> seguros = new();

    protected override async Task OnInitializedAsync()
    {
        while (!Auth.Inicializado)
        {
            await Task.Delay(50);
        }

        if (!Auth.EstaLogueado)
        {
            Nav.NavigateTo("/login");
            return;
        }
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        reserva = new ReservaResponse
        {
            ClienteDni = Auth.ClienteDni,
            ClienteNombre = Auth.ClienteNombre,
            ClienteApellido = Auth.ClienteApellido
        };

        reserva.VehiculoPatente = query["patente"] ?? "SIN-PATENTE";

        var client = HttpFactory.CreateClient("Api");

        var vehiculo = await client.GetFromJsonAsync<VehiculoResponse>($"vehiculos/{reserva.VehiculoPatente}");

        if (vehiculo != null)
        {
            vehiculoDescripcion = $"{vehiculo.MarcaNombre} {vehiculo.ModeloNombre}";
        }

        var inicioStr = query["inicio"];
        var finStr = query["fin"];

        fechaInicio = DateTime.TryParse(inicioStr, out var inicio)
            ? inicio
            : DateTime.Today;

        fechaFin = DateTime.TryParse(finStr, out var fin)
            ? fin
            : DateTime.Today.AddDays(1);

        reserva.FechaInicio = DateOnly.FromDateTime(fechaInicio);
        reserva.FechaFin = DateOnly.FromDateTime(fechaFin);

        reserva.EstadoId = 1;
        reserva.EstadoNombre = "Pendiente";
        seguros = await client.GetFromJsonAsync<List<SeguroResponse>>(
                    "seguros"
                ) ?? new();

        seguroId = seguros.FirstOrDefault()?.Id ?? 1;

        await CalcularPrecio();
    }

    private async Task ConfirmarReserva()
    {
        var client = HttpFactory.CreateClient("Api");

        try
        {

            var request = new ReservaCreateRequest
            {
                ClienteDni = reserva!.ClienteDni,
                VehiculoPatente = reserva.VehiculoPatente,
                FechaInicio = DateOnly.FromDateTime(fechaInicio),
                FechaFin = DateOnly.FromDateTime(fechaFin),
                Precio = reserva.Precio,
                Senia = reserva.Senia,
                EstadoId = 2
            };

            var response = await client.PostAsJsonAsync("reservas", request);

            if (response.IsSuccessStatusCode)
            {
                reservaExitosa = true;
                mensaje = "La reserva fue creada correctamente";

                StateHasChanged();

                await Task.Delay(1500);

                Nav.NavigateTo("/");

            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                reservaExitosa = false;
                mensaje = $"❌ {error}";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error de conexión: {ex.Message}");
        }
    }
    private async Task CalcularPrecio()
    {
        if (reserva == null)
            return;

        var client = HttpFactory.CreateClient("Api");

        var precio = await client.GetFromJsonAsync<decimal>(
            $"reservas/calcular-precio" +
            $"?patente={reserva.VehiculoPatente}" +
            $"&inicio={DateOnly.FromDateTime(fechaInicio)}" +
            $"&fin={DateOnly.FromDateTime(fechaFin)}" +
            $"&seguroId={seguroId}"
        );

        precioTotal = precio;

        reserva.Precio = precio;
    }
}

<style>
    body {
        background: #0f172a;
        color: #e5e7eb;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .titulo {
        text-align: center;
        margin-bottom: 25px;
        font-size: 26px;
    }

    .form {
        max-width: 500px;
        margin: 0 auto;
        background: #1e293b;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .vehiculo {
        background: #0f172a;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 20px;
        text-align: center;
    }

        .vehiculo span {
            display: block;
            font-size: 12px;
            color: #94a3b8;
        }

        .vehiculo strong {
            font-size: 16px;
        }

    .input-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 15px;
    }

    label {
        font-size: 13px;
        margin-bottom: 5px;
        color: #cbd5f5;
    }

    input, .form ::deep input, .form ::deep select {
        width: 100%;
        max-width: 100%;
        background: #0f172a;
        border: 1px solid #334155;
        border-radius: 8px;
        padding: 10px;
        color: #e5e7eb;
    }

        .form ::deep input[type="date"] {
            width: 100%;
        }

    .btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
        font-weight: bold;
        cursor: pointer;
        margin-top: 15px;
        transition: 0.2s;
    }

        .btn:hover {
            transform: scale(1.03);
        }

    .error {
        text-align: center;
        color: #f87171;
    }

    input, textarea, select {
        width: 100%;
        background-color: #0f172a !important;
        color: #e5e7eb !important;
        border: 1px solid #334155;
        border-radius: 8px;
        padding: 10px;
    }

    .form ::deep input {
        background-color: #0f172a !important;
        color: #e5e7eb !important;
    }

    input[type="date"]::-webkit-calendar-picker-indicator {
        filter: invert(1);
        cursor: pointer;
    }

    input::placeholder {
        color: #94a3b8;
    }

    .success {
        margin-top: 15px;
        background: rgba(34,197,94,0.15);
        border: 1px solid #22c55e;
        color: #86efac;
        padding: 12px;
        border-radius: 10px;
        text-align: center;
    }

    .error-box {
        margin-top: 15px;
        background: rgba(239,68,68,0.15);
        border: 1px solid #ef4444;
        color: #fca5a5;
        padding: 12px;
        border-radius: 10px;
        text-align: center;
    }

    .precio-box {
        margin-bottom: 15px;
        background: #0f172a;
        border: 1px solid #334155;
        border-radius: 10px;
        padding: 15px;
        text-align: center;
    }

        .precio-box span {
            display: block;
            color: #94a3b8;
            font-size: 13px;
        }

        .precio-box strong {
            font-size: 24px;
            color: #22c55e;
        }
</style>